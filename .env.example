# ─────────────────────────────────────────────────────────────────────────────
# CV Bulk Email Sender — Environment Variables (Gmail SMTP)
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file to .env:    copy .env.example .env
# 2. Fill in your real values below.
# 3. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Your Gmail address
SENDER_EMAIL=you@gmail.com

# 16-character Google App Password (NOT your normal Gmail password)
# → Get it at: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Display name shown in recipients' inbox
SENDER_NAME=Your Name

# SMTP Server settings (Defaults are for Gmail)
# For Outlook use: smtp.office365.com (Port 587)
# For Yahoo use: smtp.mail.yahoo.com (Port 587)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# uvicorn main:app --reload --port 8000
#pip install -r requirements.txt
